# Copy to .env and adjust
# ============================================================================
# Phase R2 Configuration - Full Dry-Run Integration (Step 6 Complete)
# ============================================================================

# Telegram Bot Configuration (optional for Phase R1)
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Multi-user access control (optional, overrides TELEGRAM_CHAT_ID if set)
# Supports JSON array or comma-separated formats:
# ACCESS_CONTROL_IDS=["123456789","987654321"]
# ACCESS_CONTROL_IDS=123456789,987654321

# ============================================================================
# Phase R1: Core Settings (REQUIRED)
# ============================================================================

# CRITICAL: Must be false for Phase R1 (monitoring only, no trading)
TRADING_ENABLED=false

# WebSocket streaming (recommended for low latency)
WS_ENABLED=true

# Exchanges (JSON array preferred, CSV with deprecation warning)
# Production (stable): 5 exchanges without HTX
# HTX DISABLED: WS ping/pong timeouts + ccxt.pro KeyError race (Dec 2025)
# To enable HTX: add "htx" and configure HTX_PROXY (SOCKS5 required)
EXCHANGES=["bybit","okx","mexc","gate","kucoin"]

# Limit symbols per exchange for testing (10 recommended for R1)
MAX_SYMBOLS_PER_EXCHANGE=10

# Optional: per-exchange overrides (JSON object)
# Production recommended: increase gate/mexc for better overlap
EXCHANGE_SYMBOL_LIMITS_JSON={"gate": 50, "mexc": 50}

# ============================================================================
# Adaptive Symbol Refresh (Dynamic Universe)
# ============================================================================

# Enable adaptive refresh of symbol list (recommended)
SYMBOL_REFRESH_ENABLED=true

# How often to check conditions (seconds)
SYMBOL_REFRESH_CHECK_INTERVAL_SECONDS=300

# Minimum interval between actual refreshes (seconds)
SYMBOL_REFRESH_MIN_INTERVAL_SECONDS=3600

# Refresh triggers
# - If any exchange has stale_intervals >= threshold
SYMBOL_REFRESH_STALE_INTERVALS_THRESHOLD=5
SYMBOL_REFRESH_STALE_EXCHANGES_THRESHOLD=1
# - If too few ARB OK and many rejections in the last window
SYMBOL_REFRESH_MIN_ARB_OK=1
SYMBOL_REFRESH_MIN_ARB_REJECT=200

# ============================================================================
# Profit & Liquidity Thresholds
# ============================================================================

# Minimum net profit threshold (%) - 0.3% for Phase R1
MIN_NET_PROFIT=0.3

# Trade volume for fee calculations (USD)
TRADE_VOLUME_USD=100.0

# Minimum liquidity threshold (USD) - both bid and ask must meet this
LIQUIDITY_USD_THRESHOLD=10000.0

# Price window for liquidity calculation (%) - ±0.1% default
LIQUIDITY_WINDOW_PCT=0.1

# ============================================================================
# Network & Fees
# ============================================================================

# Preferred withdrawal network (TRC20 recommended for low fees)
NETWORK_DEFAULT=TRC20

# Order book depth (50 recommended, Bybit supports: 1/50/200/1000)
ORDERBOOK_LIMIT=50

# Optional: Path to static fees JSON (if exchange APIs unreliable)
# FEES_STATIC_JSON=./fees_static.json

# ============================================================================
# REST Fallback Settings (when WS unavailable)
# ============================================================================

# Enable REST fallback when WS fails
REST_FALLBACK=true

# REST polling interval (seconds) when WS disabled
CHECK_INTERVAL_SECONDS=5

# ============================================================================
# Testing & Development
# ============================================================================

# Auto-exit after specified time (seconds) - useful for bounded testing
# RUN_DURATION_SECONDS=3600

# ============================================================================
# МДРК Trading Configuration (Phase R2 - Active Dry-Run Mode)
# ============================================================================

# Simulate trades without real orders (Phase R2 Step 6)
# Set to true for dry-run simulation (recommended for testing)
DRY_RUN_MODE=true

# Maximum simultaneous arbitrage cycles (Phase R2)
MAX_CONCURRENT_CYCLES=1

# Auto buy timeout (seconds) (Phase R2)
LEG1_TIMEOUT_SECONDS=5

# Auto sell timeout (seconds) (Phase R2)
LEG3_TIMEOUT_SECONDS=10

# Maximum position size per cycle (USD) (Phase R2)
MAX_POSITION_SIZE_USD=100.0

# ============================================================================
# Phase R3 — Telegram Integration (Semi-automatic LEG2)
# ============================================================================

# Require Telegram confirmation before proceeding with LEG2
LEG2_CONFIRM_TIMEOUT_SECONDS=120

# Cooldown for alert spam suppression
ALERT_COOLDOWN_SECONDS=30

# Send alerts in dry-run mode
DRY_RUN_ALERTS=true

# ============================================================================
# Proxy Configuration (for geographic API restrictions)
# ============================================================================

# HTTP/HTTPS Proxy for exchange API access
# Use this to bypass geographic restrictions (e.g., Bybit 403 Forbidden)
#
# Supported formats:
# - HTTP proxy:   http://host:port
# - HTTPS proxy:  https://host:port
# - SOCKS5 proxy: socks5://host:port
#
# With authentication:
# - HTTP:   http://username:password@host:port
# - SOCKS5: socks5://username:password@host:port
#
# Examples:
#
# Webshare.io (recommended, $2.99/month):
# HTTP_PROXY=http://username:password@p.webshare.io:80
# HTTPS_PROXY=http://username:password@p.webshare.io:80
#
# Local SSH tunnel (advanced):
# HTTP_PROXY=socks5://127.0.0.1:1080
# HTTPS_PROXY=socks5://127.0.0.1:1080
#
# ProxyRack:
# HTTPS_PROXY=http://username:password@premium.residentialproxies.io:9000
#
# Recommended proxy locations: Singapore, Switzerland, Netherlands
# Leave empty to use direct connection (no proxy)
HTTP_PROXY=
HTTPS_PROXY=

# HTX WS proxy (SOCKS5). Use OFF to disable proxy for testing.
# HTX_PROXY=socks5://username:password@host:port
# HTX_PROXY=OFF

# ============================================================================
# Exchange API Keys (Required for dynamic withdrawal fees)
# ============================================================================
#
# API keys are needed to fetch real-time withdrawal fees via fetch_currencies()
# Create READ-ONLY API keys on each exchange (no trading permissions needed)
#
# Security notes:
# - Use READ-ONLY keys (no trading/withdrawal permissions)
# - Never commit .env file to git (already in .gitignore)
# - Rotate keys periodically (every 3-6 months)
#
# Bybit (https://www.bybit.com/app/user/api-management)
BYBIT_API_KEY=your_bybit_api_key_here
BYBIT_SECRET=your_bybit_secret_here

# OKX (https://www.okx.com/account/my-api)
OKX_API_KEY=your_okx_api_key_here
OKX_SECRET=your_okx_secret_here
OKX_PASSWORD=your_okx_passphrase_here

# KuCoin (https://www.kucoin.com/account/api)
KUCOIN_API_KEY=your_kucoin_api_key_here
KUCOIN_SECRET=your_kucoin_secret_here
KUCOIN_PASSWORD=your_kucoin_passphrase_here

# HTX (Huobi) (https://www.htx.com/en-us/apikey/)
HTX_API_KEY=your_htx_api_key_here
HTX_SECRET=your_htx_secret_here

# Gate.io (https://www.gate.io/myaccount/apiv4keys)
GATE_API_KEY=your_gate_api_key_here
GATE_SECRET=your_gate_secret_here

# MEXC (https://www.mexc.com/user/openapi)
MEXC_API_KEY=your_mexc_api_key_here
MEXC_SECRET=your_mexc_secret_here

# ============================================================================
# Dynamic Withdrawal Fees Configuration
# ============================================================================

# Cache lifetime for withdrawal fees (seconds, default: 3600 = 1 hour)
WITHDRAWAL_FEE_CACHE_LIFETIME=3600

# Timeout for fetching fees from exchange APIs (seconds)
WITHDRAWAL_FEE_FETCH_TIMEOUT=10

# ============================================================================
# Logging Configuration (Protocol 0001)
# ============================================================================

# Console log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
# Default: WARNING (reduces terminal noise)
LOG_LEVEL_CONSOLE=WARNING

# File log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
# Default: INFO (captures more detail for analysis)
LOG_LEVEL_FILE=INFO

# Maximum log file size before rotation (bytes)
# Default: 104857600 (100 MB)
# Range: 1 MB - 1 GB
LOG_MAX_BYTES=104857600

# Number of rotated backup files to keep
# Default: 5
# Total disk usage: LOG_MAX_BYTES × (LOG_BACKUP_COUNT + 1)
# Example: 100 MB × 6 = 600 MB maximum
LOG_BACKUP_COUNT=5

# Sampling ratio for noisy log categories (WS, OB, LIQ, TICK)
# Default: 10 (log 1 out of every 10 messages)
# Set to 1 for full logging (debugging)
# Critical logs (ARB, CYCLE, LEG) always bypass sampling
LOG_SAMPLE_RATIO=10

# Time-based sampling interval in seconds (optional)
# Default: 0.0 (disabled)
# If set > 0, limits messages from same category to 1 per interval
LOG_SAMPLE_INTERVAL_SECONDS=0.0

# Comma-separated list of log prefixes to suppress entirely
# Default: "" (empty, no suppression)
# Example: "TICK,HEARTBEAT"
LOG_SUPPRESS_PREFIXES=

# ============================================================================
# Logging Quick Reference
# ============================================================================
#
# Debug mode (see all logs, no sampling):
#   LOG_LEVEL_CONSOLE=DEBUG
#   LOG_SAMPLE_RATIO=1
#
# Production mode (minimal console noise):
#   LOG_LEVEL_CONSOLE=WARNING
#   LOG_SAMPLE_RATIO=10
#
# Troubleshooting WebSocket issues:
#   LOG_LEVEL_CONSOLE=INFO
#   LOG_SAMPLE_RATIO=1
#   LOG_SUPPRESS_PREFIXES=""
#
